# Supabase (ya configurado)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_anon_or_publishable_key

# Meta / WhatsApp Embedded Signup (flujo manual)
# 1) Crea una app en https://developers.facebook.com/apps/
# 2) Añade el producto "WhatsApp" y la configuración Embedded Signup (config_id)
# 3) En "Valid OAuth Redirect URIs" añade EXACTAMENTE esta URL (con tu dominio):
#    https://TU-DOMINIO.vercel.app/auth/callback/whatsapp
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_WHATSAPP_CONFIG_ID=
META_APP_SECRET=

# Supabase: clave de servicio solo para el callback de WhatsApp (no exponer en cliente)
SUPABASE_SERVICE_ROLE_KEY=
