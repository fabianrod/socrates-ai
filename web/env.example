# Supabase (ya configurado)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_anon_or_publishable_key

# Meta / WhatsApp Embedded Signup (Fase 5)
# 1) Crea una app en https://developers.facebook.com/apps/
# 2) Añade el producto "WhatsApp" y configura "Embedded Signup"
# 3) En Facebook Login for Business > Configurations crea una configuración
#    con la plantilla "WhatsApp Embedded Signup Configuration With 60 Expiration Token"
# 4) Añade tu dominio (ej. localhost para desarrollo) en Allowed Domains y Valid OAuth Redirect URIs
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_WHATSAPP_CONFIG_ID=
META_APP_SECRET=
